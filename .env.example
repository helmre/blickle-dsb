# Digitales Schwarzes Brett - Prototype/Integration settings
#
# Copy to `.env.local` for local experiments. Do not commit real secrets.

# Demo mode keeps prototype-only helpers available in development.
# Default in code: true in dev, false in production.
VITE_DSB_DEMO_MODE=true

# Client-side password gate is only a presentation gate for demos.
# Production must use server-side auth/SSO instead.
VITE_DSB_CLIENT_PASSWORD_GATE=true

# Allows the admin header user switch in demo mode.
# Keep false for any production-like environment.
VITE_DSB_ALLOW_USER_SWITCH=true

# Future backend integration switch.
# Current implementation is local-only; use this value as the planned contract.
VITE_DSB_DATA_SOURCE=local

# Future backend base URL for an API adapter.
# Example: https://dsb-api.example.local/api/v1
VITE_DSB_API_BASE_URL=

# Future media upload endpoint. Production should return MediaAsset objects.
VITE_DSB_MEDIA_UPLOAD_URL=
